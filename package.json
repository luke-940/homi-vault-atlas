{
  "name": "homi-vault-atlas",
  "version": "7.5.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <26"
  },
  "scripts": {
    "lint": "node scripts/lint-source-contract.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.tests.json && tsc --noEmit -p tsconfig.scripts.json",
    "test": "npm run test:public",
    "test:public": "ATLAS_TEST_PROFILE=public-ci vitest run tests-public tests/v7-4-qa-contract.test.ts tests/visual-golden-contract.test.ts --maxWorkers=1",
    "test:owner": "ATLAS_TEST_PROFILE=owner-local vitest run tests-public/v75-data-boundary.test.ts --maxWorkers=1",
    "build": "node scripts/build-public-site.mjs && node scripts/audit-public-bundle.mjs",
    "audit": "node scripts/audit-public-bundle.mjs",
    "release:package": "node scripts/package-release-artifact.mjs",
    "release:verify": "node scripts/package-release-artifact.mjs --verify",
    "release:evidence": "node scripts/create-v7-4-release-evidence-inventory.mjs",
    "release:readback": "node scripts/readback-production.mjs",
    "qa:owner:local": "node scripts/run-v7-4-owner-contract-qa.mjs",
    "qa:local": "npm run qa:owner:local && ATLAS_OWNER_QA_RECEIPT=artifacts/v7-4-owner-qa/owner-contract-qa.json ATLAS_QA_MODE=local-rc node scripts/run-v7-4-qa.mjs",
    "qa:file": "ATLAS_QA_MODE=file-smoke node scripts/run-v7-4-qa.mjs",
    "qa:ci": "ATLAS_QA_MODE=ci node scripts/run-v7-4-qa.mjs",
    "qa:visual:manifest": "node scripts/verify-v7-4-visual-golden.mjs",
    "qa:visual:ci": "npm run qa:visual:manifest && ATLAS_VISUAL_BASELINE_MODE=verify npx --no-install playwright test --config=playwright.visual.config.mjs",
    "qa:visual:candidate:ci": "ATLAS_VISUAL_BASELINE_MODE=candidate npx --no-install playwright test --config=playwright.visual.config.mjs"
  },
  "dependencies": {
    "d3-array": "^3.2.4",
    "d3-chord": "^3.0.1",
    "d3-interpolate": "^3.0.1",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "lucide-react": "^1.24.0",
    "motion": "^12.42.2",
    "pretendard": "^1.3.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/d3": "^7.4.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "d3-contour": "^4.0.2",
    "d3-force": "^3.0.0",
    "es-module-lexer": "^2.3.1",
    "esbuild": "^0.28.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
